PORT=3000
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
NODE_ENV=production
FRONTEND_ORIGIN=https://your-app.vercel.app
ANTHROPIC_API_KEY=
RESEND_API_KEY=
WEBHOOK_SECRET=

# ManyChat Webhook (Instagram DMs via ManyChat)
MANYCHAT_WEBHOOK_SECRET=

# BullMQ + state management (Railway provides Redis)
REDIS_URL=

# Voice: Whisper (transcription) + ElevenLabs (TTS)
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Production Infrastructure (added Phase 1-4) ---

# Logging
LOG_LEVEL=info

# Error Tracking (Sentry)
SENTRY_DSN=

# Admin Alerts (system failures, DLQ)
ADMIN_ALERT_EMAILS=your@email.com
SLACK_ALERT_WEBHOOK=

# API Key Encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# Cloudflare R2 Storage (optional, falls back to local disk)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Email sender for admin alerts
ALERT_FROM_EMAIL=alerts@yourdomain.com
